/** Shared foundation catalogue reused by all demo projects. */
catalogue foundation_catalogue

/** Core types, events and interfaces used across the workspace examples. */
namespace demo::foundation
{
    /**
     * Percentage stored on one unsigned byte.
     * @uuid e07fea8f-8ca6-42b6-932f-d2e9646dbfa0
     */
    public integer Percentage extends Smp.UInt8 in 0 ... 100

    /**
     * Electrical bus voltage expressed in volts.
     * @uuid 70a01507-193b-4337-926d-4c80f004ff41
     */
    public float Voltage extends Smp.Float32 in 0.0 ... 50.0

    /**
     * Temperature value expressed in degrees Celsius.
     * @uuid 69ffe85b-2436-4d9a-b86f-35ac9c44e82e
     */
    public float TemperatureC extends Smp.Float32 in -120.0 ... 180.0

    /**
     * Small sample buffer used by the examples for tunings and frames.
     * @uuid bff1991b-0c39-4d90-aef4-7b824f585e8f
     */
    public array FloatSamples = Smp.Float32[4]

    /**
     * Three-axis vector used for rates and similar telemetry.
     * @uuid d5d74cd7-3f80-4147-8d24-b31ff04c31d5
     */
    public struct Vector3
    {
        /** X component. */
        field Smp.Float64 x
        /** Y component. */
        field Smp.Float64 y
        /** Z component. */
        field Smp.Float64 z
    }

    /**
     * Compact power budget snapshot shared between components.
     * @uuid d0cf7a8b-feb9-485f-8f86-19311a684edb
     */
    public struct PowerProfile
    {
        /** Main bus voltage. */
        field Voltage bus
        /** Available margin on the power line. */
        field Percentage margin
        /** Harmonic content used as a simple demo vector. */
        field FloatSamples harmonics
    }

    /**
     * Thermal regulation snapshot for one controlled loop.
     * @uuid 6e545d4e-8746-4140-a83a-097c8d71a0ba
     */
    public struct ThermalLoop
    {
        /** Measured sensor temperature. */
        field TemperatureC sensor
        /** Requested target temperature. */
        field TemperatureC target
        /** Heater drive level. */
        field Percentage heater
        /** Indicates whether regulation is enabled. */
        field Smp.Bool enabled
    }

    /**
     * Common operating mode used across the demo system.
     * @uuid f2a7d032-5669-4ddc-9d58-77dadedfcfe6
     */
    public enum Mode
    {
        /** Component is powered off. */
        Off = 0,
        /** Component is initialized but not fully active. */
        Standby = 1,
        /** Component performs nominal work. */
        Nominal = 2,
        /** Component runs in a protected fallback mode. */
        Safe = 3
    }

    /**
     * Event carrying one operating mode value.
     * @uuid 574cc8a8-e018-4af9-9a8f-e75ad4411507
     */
    public event ModeEvent extends Mode

    /**
     * Event carrying a short text message.
     * @uuid ed666253-15fc-49ff-a3ef-b3237e73cb88
     */
    public event TextEvent extends Smp.String8

    /**
     * Logging contract consumed by many examples.
     * @uuid 85e0f8aa-a74c-428a-b18c-46ac086d9d14
     */
    public interface ILogger
    {
        /** Publishes one log message. */
        def void log(in Smp.String8 message)
    }

    /**
     * Generic command interface exposing one writable operating mode.
     * @uuid 05fa2f16-91e4-4b43-bc07-e086b6a21763
     */
    public interface ICommandable
    {
        /** Current externally visible mode. */
        property Mode mode
        /** Requests a new operating mode. */
        def void apply(in Mode requestedMode)
    }

    /**
     * Read-only power bus contract published by power providers.
     * @uuid e746fe4c-6627-44dd-89f8-b153f3328265
     */
    public interface IPowerBus
    {
        /** Available bus voltage. */
        readOnly property Voltage busVoltage
        /** Remaining safety margin on the bus. */
        readOnly property Percentage margin
    }
}
