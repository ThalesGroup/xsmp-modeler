{
    "name": "@xsmp/profile-tas-mdk",
    "version": "1.97.0",
    "type": "module",
    "private": true,
    "license": "MIT",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.js"
        }
    },
    "scripts": {
        "build": "npm run build:package",
        "build:package": "tsc -p tsconfig.src.json && npm run build:assets",
        "build:vscode": "node build-vscode.mjs",
        "build:assets": "node ../../scripts/package-assets.mjs package",
        "watch": "tsc --watch -p tsconfig.src.json",
        "watch:vscode": "node build-vscode.mjs --watch",
        "lint": "eslint src build-vscode.mjs",
        "package:vscode": "npm run build:vscode && cd vscode && vsce package --no-dependencies",
        "test": "cd ../.. && npm run build && vitest run packages/xsmp-profile-tas-mdk/test --config vitest.config.ts"
    },
    "dependencies": {
        "langium": "4.2.0",
        "xsmp": "1.97.0"
    }
}
