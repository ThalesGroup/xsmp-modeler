         *
         * @id _2021x_2_f810373_1724252710114_403537_4991
         */
        LLF_Auto = 0,
        /**
         * Load the library with global flag, making the symbols available globally.
         *
         * @id _2021x_2_f810373_1724252669250_764283_4989
         */
        LLF_Global = 1,
        /**
         * Load the library with local flag, making the symbols only available locally within the library.
         *
         * @id _2021x_2_f810373_1724252601776_435304_4986
         */
        LLF_Local = 2
    }

    /**
     * The Type of a Request defines if the component shall invoke an operation, retrieve a property, or set a property.
     *
