         */
        public exception InvalidEventTime extends Smp.Exception
        {
        }

        /**
         * This exception is thrown by SetSimulationTime if the new simulation time is not between the current simulation time and the simulation time of the next event on the scheduler.
         *
         * @uuid 36d89d54-4804-32a3-a837-65ef6cf9b417
         * @id _17_0_2_5_f810373_1483027062682_587610_16894
         */
        public exception InvalidSimulationTime extends Smp.Exception
        {
            /**
             * Get the current simulation time maintained by the time keeper.
             *
             * @return Current simulation time maintained by the time keeper.
             * @id _17_0_2_5_f810373_1483027203479_205272_16947
             */
            @Attributes.Const
            public def Smp.Duration ReturnParameter GetCurrentTime()

            /**
             * Get the simulation time provided to SetSimulationTime.
             *
             * @return Simulation time provided to SetSimulationTime.
             * @id _17_0_2_5_f810373_1483027259568_176103_16952
             */
            @Attributes.Const
            public def Smp.Duration ReturnParameter GetProvidedTime()

            /**
             * Get the maximum simulation time that can be set using SetSimulationTime.
             *
             * @return Maximum simulation time that can be set using SetSimulationTime.
             * @id _17_0_2_5_f810373_1483027301831_879216_16957
             */
            @Attributes.Const
            public def Smp.Duration ReturnParameter GetMaximumTime()
        }

        /**
         * This interface gives access to the Logger Service.
         *
         * @uuid 8bd152ae-f8c6-3f8a-a517-1adec2cca232
         * @id _smp2_Smp.xml_Smp.Services.ILogger
         */
        public interface ILogger extends Smp.IService
        {
            /**
             * The message contains general information.
             *
             * @id _12_1_910029a_1199880723870_42345_2133
             */
            @Attributes.Static
            constant LogMessageKind LMK_Information = 0

            /**
             * The message has been sent from an event, typically from a state transition.
             *
             * @id _12_1_910029a_1199880788647_345057_2136
             */
            @Attributes.Static
            constant LogMessageKind LMK_Event = 1

            /**
             * The message contains a warning.
             *
             * @id _12_1_910029a_1199880814426_981492_2142
             */
            @Attributes.Static
            constant LogMessageKind LMK_Warning = 2

            /**
             * The message has been raised because of an error.
             *
             * @id _12_1_910029a_1199880823066_999805_2145
             */
            @Attributes.Static
            constant LogMessageKind LMK_Error = 3

            /**
             * The message contains debug information.
             *
             * @id _12_1_910029a_1199880831659_166595_2148
             */
            @Attributes.Static
            constant LogMessageKind LMK_Debug = 4

            /**
             * The message contains general information.
             *
             * @id _12_1_910029a_1199880940119_282446_2159
             */
            @Attributes.Static
            constant Smp.String8 LMK_InformationName = "Information"

            /**
             * The message contains debug information.
             *
             * @id _12_1_910029a_1199880940119_618373_2156
             */
            @Attributes.Static
            constant Smp.String8 LMK_DebugName = "Debug"

            /**
             * The message has been raised because of an error.
             *
             * @id _12_1_910029a_1199880940119_894969_2157
             */
            @Attributes.Static
            constant Smp.String8 LMK_ErrorName = "Error"

            /**
             * The message contains a warning.
             *
             * @id _12_1_910029a_1199880940119_680406_2160
             */
            @Attributes.Static
            constant Smp.String8 LMK_WarningName = "Warning"

            /**
             * The message has been sent from an event, typically from a state transition.
             *
             * @id _12_1_910029a_1199880940119_108524_2158
             */
            @Attributes.Static
            constant Smp.String8 LMK_EventName = "Event"

            /**
             * Return identifier of log message kind by name.
             *
             * @param messageKindName Name of log message kind.
             * @return Identifier of log message kind.
             * @id _smp2_Smp.xml_Smp.Services.ILogger.GetLogMessageKind
             */
            def LogMessageKind ReturnParameter QueryLogMessageKind(in Smp.String8 messageKindName)

            /**
             * This function logs a message to the simulation log.
             *
             * @param sender Object that sends the message.
             * @param message The message to log.
             * @param kind Kind of message.
             * @id _smp2_Smp.xml_Smp.Services.ILogger.Log
             */
            def void Log(@Attributes.Const in Smp.IObject sender, in Smp.String8 message, in LogMessageKind kind = 0)
        }

        /**
         * This type is used as identifier of a log message kind.
         *
         * @uuid bb5f064a-43a7-329c-9f4b-b9f7beff84a2
         * @id _smp2_Smp.xml_Smp.Services.LogMessageKind
         */
        public integer LogMessageKind extends Smp.Int32 in 0 ... 2147483647

        /**
         * This interface gives access to the Time Keeper Service.
         *
         * @uuid b9a8fd26-5998-3670-9eec-75afeb9980d1
         * @id _smp2_Smp.xml_Smp.Services.ITimeKeeper
         */
        public interface ITimeKeeper extends Smp.IService
        {
            /**
             * Return Simulation time.
             *
             * @return Current simulation time.
             * @id _smp2_Smp.xml_Smp.Services.ITimeKeeper.GetSimulationTime
             */
            @Attributes.Const
            def Smp.Duration ReturnParameter GetSimulationTime()

            /**
             * Return Epoch time.
             *
             * @return Current epoch time.
             * @id _smp2_Smp.xml_Smp.Services.ITimeKeeper.GetEpochTime
             */
            @Attributes.Const
            def Smp.DateTime ReturnParameter GetEpochTime()

            /**
             * Get mission start time.
             *
             * @return Mission start date and time.
             * @id _17_0_2_5_f810373_1524584123873_667120_14527
             */
            @Attributes.Const
            def Smp.DateTime ReturnParameter GetMissionStartTime()

            /**
             * Return Mission time.
             *
             * @return Current mission time.
             * @id _smp2_Smp.xml_Smp.Services.ITimeKeeper.GetMissionTime
             */
            @Attributes.Const
            def Smp.Duration ReturnParameter GetMissionTime()

            /**
             * Return Zulu time.
             *
             * @return Current Zulu time.
             * @id _smp2_Smp.xml_Smp.Services.ITimeKeeper.GetZuluTime
             */
            @Attributes.Const
            def Smp.DateTime ReturnParameter GetZuluTime()

            /**
             * Manually advance Simulation time.
             *
             * @param simulationTime New value of simulation time to set in the Time Keeper. This has to be in the future.
             * @id _17_0_2_5_f810373_1482249667309_876505_11522
             */
            def void SetSimulationTime(in Smp.Duration simulationTime) throws InvalidSimulationTime

            /**
             * Set Epoch time.
             *
             * @param epochTime New epoch time.
             * @id _smp2_Smp.xml_Smp.Services.ITimeKeeper.SetEpochTime
             */
            def void SetEpochTime(in Smp.DateTime epochTime)

            /**
             * Set Mission time by defining the mission start time.
             * In future calls to GetMissionTime, the mission time is calculated using the formula MissionTime = EpochTime – missionStart.
             *
             * @param missionStart New mission start date and time.
             * @id _smp2_Smp.xml_Smp.Services.ITimeKeeper.SetMissionStart
             */
            def void SetMissionStartTime(in Smp.DateTime missionStart)

            /**
             * Set Mission time by providing the current mission time.
             * This effectively sets the MissionStartTime using the formula MissionStartTime = EpochTime - missionTime.
             *
             * @param missionTime New mission time.
             * @id _smp2_Smp.xml_Smp.Services.ITimeKeeper.SetMissionTime
             */
            def void SetMissionTime(in Smp.Duration missionTime)
        }

        /**
         * Enumeration of supported time kinds.
