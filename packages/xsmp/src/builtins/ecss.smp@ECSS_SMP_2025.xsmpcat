         */
        AK_ReadOnly = 1,
        /**
         * Write only access, i.e. only setter method.
         *
         * @id _12_1_910029a_1204813082693_715414_3716
         */
        AK_WriteOnly = 2
    }

    /**
     * This flag defines whether the symbols in a library shall be loaded as local symbols, global symbolds, or using the default setting of the simulation infrastructure.
     *
     * @uuid 3eb3a633-bc6a-335f-a06a-1d92554f5b2e
     * @id _2021x_2_f810373_1724252507965_124118_4978
     */
    public enum LibraryLoadingFlag
    {
        /**
