    /**
     * A request holds information, which is passed between a client invoking an operation via the IDynamicInvocation interface and a component being invoked.
     *
     * @uuid d756fbdd-0290-35ef-9a5b-61520f79ad04
     * @id _smp2_Smp.xml_Smp.IRequest
     */
    public interface IRequest
    {
        /**
         * If request type is Invoke, return the name of the Operation to invoke.
         * If request type is Get or Set, return the name of the Property to access.
         *
         * @return Name of the operation.
         * @id _smp2_Smp.xml_Smp.IRequest.GetOperationName
         */
        @Attributes.Const
        def String8 ReturnParameter GetName()

        /**
         * Return the type of the request.
         *
         * @return Type of the request.
         * @id _2021x_2_126903bf_1724939901895_229051_14570
         */
        @Attributes.Const
        def RequestType ReturnParameter GetType()

        /**
         * Return the number of parameters stored in the request.
         * This only considers parameters of direction in, out or in/out, but not of type return.
         *
         * @return Number of parameters in request object.
         * @id _smp2_Smp.xml_Smp.IRequest.GetParameterCount
         */
        @Attributes.Const
        def Int32 ReturnParameter GetParameterCount()

        /**
         * Query for a parameter index by parameter name.
         * This only considers parameters of direction in, out or in/out, but not of type return.
         *
         * @param parameterName Name of parameter.
         * @return Index of parameter with the given name, or -1 if no parameter with the given name could be found.
         * @id _smp2_Smp.xml_Smp.IRequest.GetParameterIndex
         */
        @Attributes.Const
        def Int32 ReturnParameter GetParameterIndex(in String8 parameterName)

        /**
         * Assign a value to a parameter at a given position.
         * This only considers parameters of direction in, out or in/out, but not of type return.
         *
         * @param index Index of parameter (0-based).
         * @param value Value of parameter.
         * @id _smp2_Smp.xml_Smp.IRequest.SetParameterValue
         */
        def void SetParameterValue(in Int32 index, in AnySimple value) throws InvalidParameterIndex, InvalidParameterValue

        /**
         * Query a value of a parameter at a given position.
         * This only considers parameters of direction in, out or in/out, but not of type return.
         *
         * @param index Index of parameter (0-based).
         * @return Value of parameter. 
         * @id _smp2_Smp.xml_Smp.IRequest.GetParameterValue
         */
        @Attributes.Const
        def AnySimple ReturnParameter GetParameterValue(in Int32 index) throws InvalidParameterIndex

        /**
         * Assign the return value of the operation.
         *
         * @param value Return value.
         * @id _smp2_Smp.xml_Smp.IRequest.SetReturnValue
         */
        def void SetReturnValue(in AnySimple value) throws VoidOperation, InvalidParameterValue

        /**
         * Query the return value of the operation.
         *
         * @return Return value of the operation.
         * @id _smp2_Smp.xml_Smp.IRequest.GetReturnValue
         */
        @Attributes.Const
        def AnySimple ReturnParameter GetReturnValue() throws VoidOperation
    }

