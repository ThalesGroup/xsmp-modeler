    /**
     * This interface is implemented by a Field that can take part as output field in direct inter-component data flow.
     *
     * @uuid 3503274b-8746-398e-8f8a-79d7c35a2e5e
     * @id _17_0_2_5_f810373_1482851986402_929923_14065
     */
    public interface IOutputField extends IField
    {
        /**
         * Connect this field to a target field for direct data flow.
         * As the Push() operation only requires to set a value, the target field can be any field (it does not need to implement a specific interface for an input field).
         *
         * @param target Target field to connect to. The field type must be compatible.
         * @id _17_0_2_5_f810373_1482852059348_190799_14087
         */
        def void Connect(inout IField target) throws InvalidTarget, FieldAlreadyConnected

        /**
         * Disconnect a target field (that has been connected before) from this field.
         *
         * @param target Target field to disconnect. The field must have been connected before.
         * @id _2021x_2_f810373_1724242444178_997974_4368
         */
        def void Disconnect(inout IField target) throws FieldNotConnected

        /**
         * Push the current field value to all connected target fields.
         *
         * @id _17_0_2_5_f810373_1482852190825_658651_14094
         */
        def void Push()

        /**
         * Collection of fields that have been connected to the output field for data flow.
         *
         * @return Collection of fields that have been connected to the ouput field.
         * @id _2021x_2_f810373_1724253757725_613715_5890
         */
        @Attributes.Const
        def @Attributes.ByPointer @Attributes.Const FieldCollection ReturnParameter GetInputFields()

        /**
         * Flag to check whether the output field supports automatic data propagation (i.e. automatic Push() each time the field value is changed) or not.
         *
         * @return True if the output field supports automatic data propagation, false otherwise.
         * @id _2021x_2_f810373_1724407845216_507281_4092
         */
        @Attributes.Const
        def Bool ReturnParameter IsAutomatic()
    }

