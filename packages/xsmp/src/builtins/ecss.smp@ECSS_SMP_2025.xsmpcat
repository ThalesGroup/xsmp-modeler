             */
            @Attributes.Const
            public def @Attributes.Const Smp.IEntryPoint ReturnParameter GetEntryPoint()

            /**
             * Get the name of the event that the entry point is already subscribed to.
             *
             * @return Name of the event that the entry point is already subscribed to.
             * @id _17_0_2_5_f810373_1482355456718_332700_17670
             */
            @Attributes.Const
            public def Smp.String8 ReturnParameter GetEventName()
        }

        /**
