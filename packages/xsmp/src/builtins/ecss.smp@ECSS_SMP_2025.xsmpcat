             * @param output True if field is an output field, false otherwise.
             * @return Reference to the field that has been created by the publication call.
             * @id _12_1_910029a_1204810847934_534513_3373
             */
            def Smp.IField ReturnParameter PublishField(in Smp.String8 name, in Smp.String8 description, inout Smp.UInt8 address, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish a UInt16 field with the given name, description, address, view kind and state, input and output flags.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             *
             * @param name Field name.
             * @param description Field description.
             * @param address Field memory address.
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @param input True if field is an input field, false otherwise.
             * @param output True if field is an output field, false otherwise.
             * @return Reference to the field that has been created by the publication call.
             * @id _12_1_910029a_1204810850840_443786_3397
             */
            def Smp.IField ReturnParameter PublishField(in Smp.String8 name, in Smp.String8 description, inout Smp.UInt16 address, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish a UInt32 field with the given name, description, address, view kind and state, input and output flags.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             *
             * @param name Field name.
             * @param description Field description.
             * @param address Field memory address.
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @param input True if field is an input field, false otherwise.
             * @param output True if field is an output field, false otherwise.
             * @return Reference to the field that has been created by the publication call.
             * @id _12_1_910029a_1204810851293_151863_3421
             */
            def Smp.IField ReturnParameter PublishField(in Smp.String8 name, in Smp.String8 description, inout Smp.UInt32 address, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish a UInt64 field with the given name, description, address, view kind and state, input and output flags.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             *
             * @param name Field name.
             * @param description Field description.
             * @param address Field memory address.
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @param input True if field is an input field, false otherwise.
             * @param output True if field is an output field, false otherwise.
             * @return Reference to the field that has been created by the publication call.
             * @id _12_1_910029a_1204810851684_972179_3445
             */
            def Smp.IField ReturnParameter PublishField(in Smp.String8 name, in Smp.String8 description, inout Smp.UInt64 address, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish a Float32 field with the given name, description, address, view kind and state, input and output flags.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             *
             * @param name Field name.
             * @param description Field description.
             * @param address Field memory address.
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @param input True if field is an input field, false otherwise.
             * @param output True if field is an output field, false otherwise.
             * @return Reference to the field that has been created by the publication call.
             * @id _12_1_910029a_1204810852325_605398_3469
             */
            def Smp.IField ReturnParameter PublishField(in Smp.String8 name, in Smp.String8 description, inout Smp.Float32 address, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish a Float64 field with the given name, description, address, view kind and state, input and output flags.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             *
             * @param name Field name.
             * @param description Field description.
             * @param address Field memory address.
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @param input True if field is an input field, false otherwise.
             * @param output True if field is an output field, false otherwise.
             * @return Reference to the field that has been created by the publication call.
             * @id _12_1_910029a_1204810853418_516617_3493
             */
            def Smp.IField ReturnParameter PublishField(in Smp.String8 name, in Smp.String8 description, inout Smp.Float64 address, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish a field of any type with the given name, description, address, type, view kind and state, input and output flags.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             * If no type with the given type UUID exists, an exception of type TypeNotRegistered is thrown.
             * If publication type is not suitable for field publication (e.g. String8), it throws an exception of type InvalidType.
             *
             * @param name Field name.
             * @param description Field description.
             * @param address Field memory address.
             * @param typeUuid Uuid of field type (determines the size).
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @param input True if field is an input field, false otherwise.
             * @param output True if field is an output field, false otherwise.
             * @return Reference to the field that has been created by the publication call.
             * @id _12_1_910029a_1204810853856_765516_3517
             */
            def Smp.IField ReturnParameter PublishField(in Smp.String8 name, in Smp.String8 description, inout Smp.Void address, in Smp.Uuid typeUuid, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws TypeNotRegistered, Smp.InvalidType, Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish a field defined internally that implements the IField interface.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             *
             * @param field Field to publish.
             * @id _17_0_2_5_f810373_1482853007393_693943_14240
             */
            def void PublishField(inout Smp.IField field) throws Smp.DuplicateName

            /**
             * Publish top-level object of an array without using the type registry.
             * This operation can be used, together with subsequent calls to PublishField, for direct publication of an array.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             *
             * @param name Array name.
             * @param description Array description.
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @return Interface to publish item type against.
             * @id _12_1_910029a_1204812112052_454078_3619
             */
            def IPublishField ReturnParameter PublishArray(in Smp.String8 name, in Smp.String8 description, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true) throws Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish array of simple type.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             * If primitive type is not suitable for simple array field publication (i.e. None, String8), it throws an exception of type InvalidType.
             *
             * @param name Field name.
             * @param description Field description.
             * @param count Size of array.
             * @param address Field memory address.
             * @param type Array item type.
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @param input True if field is an input field, false otherwise.
             * @param output True if field is an output field, false otherwise.
             * @return Reference to the simple array field that has been created by the publication call.
             * @id _12_1_910029a_1204810854559_723037_3541
             */
            def Smp.ISimpleArrayField ReturnParameter PublishArray(in Smp.String8 name, in Smp.String8 description, in Smp.Int64 count, inout Smp.Void address, in Smp.PrimitiveTypeKind type, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws Smp.InvalidType, Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Publish top-level object of a structure without using the type registry.
             * This operation can be used, together with subsequent calls to PublishField, for direct publication of a structure.
             * If an object with the same name has been published before, an exception of type DuplicateName is thrown.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             *
             * @param name Structure name.
             * @param description Structure description.
             * @param view Show field in model tree.
             * @param state Include field in store/restore of simulation state.
             * @return Reference to publish structure fields against.
             * @id _12_1_910029a_1204812172570_260204_3648
             */
            def IPublishField ReturnParameter PublishStructure(in Smp.String8 name, in Smp.String8 description, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true) throws Smp.DuplicateName, Smp.InvalidObjectName

            /**
             * Get the field of given name.
             *
             * @param fullName Fully qualified field name (relative to the component).
             * @return Instance of field for given full name, or nullptr if no field exists with the given name.
             * @id _17_0_2_5_f810373_1482853192456_632061_14244
             */
            @Attributes.Const
            def Smp.IField ReturnParameter GetField(in Smp.String8 fullName)

            /**
             * Returns a collection of all fields that have been published.
             *
             * @return Collection of the fields (immediate children) of the component.
             * @id _17_0_2_5_f810373_1524570707792_936330_10086
             */
            @Attributes.Const
            def @Attributes.ByPointer @Attributes.Const Smp.FieldCollection ReturnParameter GetFields()
        }

        /**
         * This exception is raised when trying to add a literal to an enumeration using a value that has been used for another literal before.
         *
         * @uuid e5a9eae1-3588-329e-8ea1-38eab54cee60
         * @id _17_0_2_5_f810373_1524576726254_667817_11757
         */
        public exception DuplicateLiteral extends Smp.Exception
        {
            /**
             * Get the name of the literal that has been added before using the same value.
             *
             * @return Name of the literal.
             * @id _17_0_2_5_f810373_1524576726254_480725_11758
             */
            @Attributes.Const
            public def Smp.String8 ReturnParameter GetLiteralName()

            /**
             * Get the value of the literal that has been used before.
             *
             * @return Value of the literal.
             * @id _17_0_2_5_f810373_1524576726254_977686_11759
             */
            @Attributes.Const
            public def Smp.Int32 ReturnParameter GetLiteralValue()
        }

        /**
         * This exception is raised when trying to register a simple array type, but the itemTypeUuid does not refer to a simple type.
         *
         * @uuid 417c6d1e-1081-3cf5-862d-cb7e968a7fbc
         * @id _2021x_2_f810373_1740749615027_432846_3928
         */
        public exception InvalidArrayItemType extends Smp.Exception
        {
            /**
             * Get the name of the invalid type that cannot be used.
             *
             * @return Name of the new type that cannot be registered.
             * @id _2021x_2_f810373_1740749615028_654678_3932
             */
            @Attributes.Const
            public def Smp.String8 ReturnParameter GetTypeName()

            /**
             * Get the invalid type that cannot be used.
             *
             * @return Type that uses the same Uuid.
             * @id _2021x_2_f810373_1740749615029_850775_3933
             */
            @Attributes.Const
            public def Smp.PrimitiveTypeKind ReturnParameter GetType()
        }

        /**
         * This exception is raised when trying to add a second return parameter to an Operation.
         *
         * @uuid 479ffa9e-b69f-3784-a035-f5645dbeae77
         * @id _2021x_2_f810373_1724427304335_900226_6837
         */
        public exception InvalidParameterDirection extends Smp.Exception
        {
            /**
             * Get the name of the invalid parameter that cannot be added.
             *
             * @return Name of the new parameter that cannot be added.
             * @id _2021x_2_f810373_1724427304337_496531_6841
             */
            @Attributes.Const
            public def Smp.String8 ReturnParameter GetParameterName()
        }

        /**
         * This exception is raised when trying to use an invalid primitive type kind as parameter for a user-defined float or integer type.
         *
         * @uuid 8f159e40-1abb-30b8-9645-ddd39582cff0
         * @id _17_0_2_5_f810373_1524123403265_476795_9548
         */
        public exception InvalidPrimitiveType extends Smp.Exception
        {
            /**
             * Get the name of the invalid type that cannot be used.
             *
             * @return Name of the invalid type that cannot be used.
             * @id _17_0_2_5_f810373_1524123403265_811259_9549
             */
            @Attributes.Const
            public def Smp.String8 ReturnParameter GetTypeName()

            /**
             * Get the invalid type that cannot be used.
             *
             * @return Invalid type that cannot be used.
             * @id _17_0_2_5_f810373_1524123403265_486240_9550
             */
            @Attributes.Const
            public def Smp.PrimitiveTypeKind ReturnParameter GetType()
        }

        /**
         * This exception is raised when trying to register a type with a Uuid that has already been registered.
         *
         * @uuid 9f2eac5e-4f7f-3535-b33c-8f5adb819a15
         * @id _12_1_910029a_1200589509531_467214_5130
         */
        public exception TypeAlreadyRegistered extends Smp.Exception
        {
            /**
             * Get the name of the new type that cannot be registered.
             *
             * @return Name of the new type that cannot be registered.
             * @id _17_0_2_5_f810373_1482354305528_941930_16776
             */
            @Attributes.Const
            public def Smp.String8 ReturnParameter GetTypeName()

            /**
             * Get the type that uses the same Uuid.
             *
             * @return Type that uses the same Uuid.
             * @id _17_0_2_5_f810373_1482354374807_563949_16780
             */
            @Attributes.Const
            public def @Attributes.Const IType ReturnParameter GetType()
        }

        /**
         * This exception is raised when trying to publish a feature with a type Uuid that has not been registered.
         *
         * @uuid 3508aeec-40bd-3457-a49c-205f32dbcae9
         * @id _12_1_910029a_1200589018027_350749_5123
         */
        public exception TypeNotRegistered extends Smp.Exception
        {
            /**
             * Get the Uuid for which no type has been registered.
             *
             * @return Uuid for which no type has been registered.
             * @id _17_0_2_5_f810373_1482354986788_47600_17210
             */
            @Attributes.Const
            public def Smp.Uuid ReturnParameter GetUuid()
        }

        /**
         * The Parameter Direction Kind enumeration defines the possible parameter directions.
         *
         * @uuid 6804426b-65b0-3a06-bcdd-5a260beb0f0b
         * @id _12_1_910029a_1205406863262_642121_4248
         */
        public enum ParameterDirectionKind
        {
            /**
             * The parameter is read-only to the operation, i.e. its value must be specified on call, and cannot be changed inside the operation.
             *
             * @id _12_1_910029a_1205406871336_70303_4249
             */
            PDK_In = 0,
            /**
             * The parameter is write-only to the operation, i.e. its value is unspecified on call, and must be set by the operation.
             *
             * @id _12_1_910029a_1205406893855_290306_4250
             */
            PDK_Out = 1,
            /**
             * The parameter must be specified on call, and may be changed by the operation.
             *
             * @id _12_1_910029a_1205406902709_790109_4251
             */
            PDK_InOut = 2,
            /**
             * The parameter represents the operation's return value.
             *
             * @id _12_1_910029a_1205406911407_266607_4252
             */
            PDK_Return = 3
        }

        /**
         * This interface defines a registration mechanism for user defined types.
         *
         * @uuid 6f421e02-3f15-3881-9953-cd65b225fc89
         * @id _smp2_Smp.xml_Smp.Publication.ITypeRegistry
         */
        public interface ITypeRegistry
        {
            /**
             * Returns a type by its primitive type kind.
             *
             * @param type Primitive type the type is requested for.
             * @return Interface to the requested type.
             * @id _12_1_910029a_1200589640127_220577_5138
             */
            @Attributes.Const
            def IType ReturnParameter GetType(in Smp.PrimitiveTypeKind type)

            /**
             * Returns a type by universally unique identifier.
             *
             * @param typeUuid Universally unique identifier for the requested type.
             * @return Interface of the requested type, or nullptr if no type with the registered Uuid could be found.
             * @id _12_1_910029a_1200589730931_433194_5146
             */
            @Attributes.Const
            def IType ReturnParameter GetType(in Smp.Uuid typeUuid)

            /**
             * Add a float type to the registry.
             *
             * @param name Name of the type.
             * @param description Description of the type.
             * @param typeUuid Universally unique identifier of the type.
             * @param minimum Minimum value for float.
             * @param maximum Maximum value for float.
             * @param minInclusive Flag whether the minimum value for float is valid or not.
             * @param maxInclusive Flag whether the maximum value for float is valid or not.
             * @param unit Unit of the type.
             * @param type Primitive type to use for Float type. This has to be either PTK_Float32 or PTK_Float64. For all other types, an exception of type InvalidPrimitiveType is raised.
             * @return Interface to new type.
             * @id _12_1_910029a_1200589840216_216905_5154
             */
            def IType ReturnParameter AddFloatType(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid typeUuid, in Smp.Float64 minimum, in Smp.Float64 maximum, in Smp.Bool minInclusive, in Smp.Bool maxInclusive, in Smp.String8 unit, in Smp.PrimitiveTypeKind type = Smp.PrimitiveTypeKind.PTK_Float64) throws TypeAlreadyRegistered, InvalidPrimitiveType, Smp.InvalidObjectName

            /**
             * Add an integer type to the registry.
             *
             * @param name Name of the type.
             * @param description Description of the type.
             * @param typeUuid Universally unique identifier of the type.
             * @param minimum Minimum value for integer.
             * @param maximum Maximum value for integer.
             * @param unit Unit of the type.
             * @param type Primitive type to use for Integer type. This has to be one of the available signed or unsigned integer types. For all other types, an exception of type InvalidPrimitiveType is raised.
             * @return Interface to new type.
             * @id _12_1_910029a_1200590141107_464365_5175
             */
            def IType ReturnParameter AddIntegerType(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid typeUuid, in Smp.Int64 minimum, in Smp.Int64 maximum, in Smp.String8 unit, in Smp.PrimitiveTypeKind type = Smp.PrimitiveTypeKind.PTK_Int32) throws TypeAlreadyRegistered, InvalidPrimitiveType, Smp.InvalidObjectName

            /**
             * Add an enumeration type to the registry.
             *
             * @param name Name of the type.
             * @param description Description of the type.
             * @param typeUuid Universally unique identifier of the type.
             * @return Interface to new type.
             * @id _12_1_910029a_1200590345758_613148_5200
             */
            def IEnumerationType ReturnParameter AddEnumerationType(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid typeUuid) throws TypeAlreadyRegistered, Smp.InvalidObjectName

            /**
             * Add an array type to the registry.
             *
             * @param name Name of the type.
             * @param description Description of the type.
             * @param typeUuid Universally unique identifier of the type.
             * @param itemTypeUuid Universally unique identifier of the Type of the array items.
             * @param itemSize Size of an array item in bytes. This needs to take possible padding into account, as it may be used by the simulation environment to calculate the memory offset between array items.
             * @param arrayCount Number of elements in the array.
             * @param simpleArray True if array shall be implemented using ISimpleArrayField, i.e. without representing array items as fields.
             * @return Interface to new type.
             * @id _12_1_910029a_1200590527755_296006_5224
             */
            def IArrayType ReturnParameter AddArrayType(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid typeUuid, in Smp.Uuid itemTypeUuid, in Smp.UInt64 itemSize, in Smp.UInt64 arrayCount, in Smp.Bool simpleArray = false) throws TypeAlreadyRegistered, TypeNotRegistered, InvalidArrayItemType, Smp.InvalidObjectName

            /**
             * Add a string type to the registry.
             *
             * @param name Name of the type.
             * @param description Description of the type.
             * @param typeUuid Universally unique identifier of the type.
             * @param length Maximum length of the string.
             * @return Interface to new type.
             * @id _12_1_910029a_1200590717189_955139_5242
             */
            def IStringType ReturnParameter AddStringType(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid typeUuid, in Smp.UInt64 length) throws TypeAlreadyRegistered, Smp.InvalidObjectName

            /**
             * Add a structure type to the registry.
             *
             * @param name Name of the type.
             * @param description Description of the type.
             * @param typeUuid Universally unique identifier of the type.
             * @return Interface to new type that allows adding fields.
             * @id _12_1_910029a_1200590805852_593518_5259
             */
            def IStructureType ReturnParameter AddStructureType(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid typeUuid) throws TypeAlreadyRegistered, Smp.InvalidObjectName

            /**
             * Add a class type to the registry.
             *
             * @param name Name of the type.
             * @param description Description of the type.
             * @param typeUuid Universally unique identifier of the type.
             * @param baseClassUuid Universally unique identifier of the base class.
            Use Uuid_Void when the type has no base type.
             * @return Interface to new type that allows adding fields.
             * @id _12_1_910029a_1200590877313_281377_5272
             */
            def IClassType ReturnParameter AddClassType(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid typeUuid, in Smp.Uuid baseClassUuid) throws TypeAlreadyRegistered, Smp.InvalidObjectName
        }

        /**
         * This base interface defines a type in the type registry.
         *
         * @uuid fff843ed-221b-3ca1-8037-2e7ce406d402
         * @id _smp2_Smp.xml_Smp.Publication.IType
         */
        public interface IType extends Smp.IObject
        {
            /**
             * Get primitive type kind that this type maps to, or PTK_None when the type cannot be mapped to a primitive type.
             *
             * @return Primitive type kind that this type can be mapped to, or PTK_None for none.
             * @id _smp2_Smp.xml_Smp.Publication.IType.GetSimpleType
             */
            @Attributes.Const
            def Smp.PrimitiveTypeKind ReturnParameter GetPrimitiveTypeKind()

            /**
             * Get Universally Unique Identifier of type.
             *
             * @return Universally Unique Identifier of type.
             * @id _smp2_Smp.xml_Smp.Publication.IType.GetUuid
             */
            @Attributes.Const
            def Smp.Uuid ReturnParameter GetUuid()

            /**
             * Publish an instance of the type against a receiver.
             * Exceptions that may be raised by the publication receiver are propagated to the caller.
             *
             * @param receiver Receiver to publish against.
             * @param name Name of instance.
             * @param description Description of instance.
             * @param address Address of instance.
             * @param view View kind of instance.
             * @param state State flag of field. When true, the field shall be part of store/restore of the simulation state.
             * @param input Input flag of field. When true, the field can be used as target of a dataflow connection.
             * @param output Output flag of field. When true, the field can be used as source of a dataflow connection.
             * @return Reference to the field that has been created by the publication call.
             * @id _12_1_910029a_1200588651620_424411_5103
             */
            def Smp.IField ReturnParameter Publish(inout IPublishField receiver, in Smp.String8 name, in Smp.String8 description, inout Smp.Void address, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws TypeNotRegistered, Smp.InvalidType, Smp.DuplicateName, Smp.InvalidObjectName
        }

        /**
         * This interface defines a user defined enumeration type.
         *
         * @uuid 817c547b-bfc1-3f94-a016-0224f38c92d7
         * @id _smp2_Smp.xml_Smp.Publication.IEnumerationType
         */
        public interface IEnumerationType extends IType
        {
            /**
             * Add a literal to the Enumeration.
             * If the name is not a valid object name, an exception of type InvalidObjectName is thrown.
             * If the name has already been used for another literal, an exception of type DuplicateName is thrown.
             * If the value has already been used for another literal, a exception of type DuplicateLiteral is thrown.
             *
             * @param name Name of the literal.
             * @param description Description of the literal.
             * @param value Value of the literal
             * @id _smp2_Smp.xml_Smp.Publication.IEnumerationType.AddLiteral
             */
            def void AddLiteral(in Smp.String8 name, in Smp.String8 description, in Smp.Int32 value) throws Smp.InvalidObjectName, Smp.DuplicateName, DuplicateLiteral
        }

        /**
         * This interface defines a user defined array type.
         *
         * @uuid f72d7cb8-d5a9-32ce-87ef-a58cbd45e606
         * @id _17_0_2_5_f810373_1524122143549_847729_9236
         */
        public interface IArrayType extends IType
        {
            /**
             * Get the size (number of array items) of the array type.
             *
             * @return Size (number of array items) of the array type.
             * @id _17_0_2_5_f810373_1524122456079_243875_9534
             */
            @Attributes.Const
            def Smp.UInt64 ReturnParameter GetSize()

            /**
             * Get the type of each array item.
             * Within one array, each array item needs to be of the same type.
             *
             * @return Type of each array item.
             * @id _17_0_2_5_f810373_1524122456079_995466_9535
             */
            @Attributes.Const
            def @Attributes.Const IType ReturnParameter GetItemType() throws TypeNotRegistered
        }

        /**
         * This interface defines a user defined array type.
         *
         * @uuid cac446ff-2c4f-305f-83b4-fef8f699f30f
         * @id _2021x_2_f810373_1740747964762_971212_3545
         */
        public interface IStringType extends IType
        {
            /**
             * Get the maximum length of the string, excluding the last null character.
             *
             * @return Size (number of array items) of the array type.
             * @id _2021x_2_f810373_1740747964768_37122_3555
             */
            @Attributes.Const
            def Smp.UInt64 ReturnParameter GetMaxLength()
        }

        /**
         * This interface defines a user defined structure type.
         *
         * @uuid 04fd9cee-ab3d-3819-b44d-b491aef1db0d
         * @id _smp2_Smp.xml_Smp.Publication.IStructureType
         */
        public interface IStructureType extends IType
        {
            /**
             * Add a field to the Structure.
             * Throws DuplicateName if a field with this name has already been added before.
             * Throws InvalidObjectName if the given name is not a valid field name for a structure field.
             * Throws TypeNotRegistered if no type with the given type UUID exists.
             * Throws InvalidType if publication type is not suitable for field publication (e.g. String8).
             *
             * @param name Name of field.
             * @param description Description of field.
             * @param uuid Uuid of field Type, which must be a value type, but not String8.
             * @param offset Memory offset of field relative to Structure.
             * @param view View kind of field.
             * @param state State flag of field. When true, the field shall be part of store/restore of the simulation state.
             * @param input Input flag of field. When true, the field can be used as target of a dataflow connection.
             * @param output Output flag of field. When true, the field can be used as source of a dataflow connection.
             * @id _smp2_Smp.xml_Smp.Publication.IStructureType.AddField
             */
            def void AddField(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid uuid, in Smp.UInt64 offset, in Smp.ViewKind view = Smp.ViewKind.VK_All, in Smp.Bool state = true, in Smp.Bool input = false, in Smp.Bool output = false) throws Smp.DuplicateName, Smp.InvalidObjectName, TypeNotRegistered, Smp.InvalidType
        }

        /**
         * This interface defines a user defined class type.
         *
         * @uuid 21c6f281-446c-3abc-bed2-1cae4cea7c0d
         * @id _smp2_Smp.xml_Smp.Publication.IClassType
         */
        public interface IClassType extends IStructureType
        {
        }

        /**
         * This interface provides functionality to publish operation parameters.
         *
         * @uuid f8697c16-e94f-38f7-a42d-a988341829bf
         * @id _smp2_Smp.xml_Smp.Publication.IPublishOperation
         */
        public interface IPublishOperation
        {
            /**
             * Publish a parameter of an operation with the given name, description, type and direction.
             * If the name is not a valid name, an exception of type InvalidObjectName is thrown.
             * If a parameter with the same name has already been published, and exception of type DuplicateName is thrown.
             * If no type with the given type UUID exists, an exception of type TypeNotRegistered is thrown.
             * If the parameter is of type return, but another parameter of type return has already been published for the same operation, it throws an exception of type InvalidParameterDirection.
             * It the primitive type kind of the publication type is None, it throws an exception of type InvalidType.
             *
             * @param name Name of parameter.
             * @param description Description of parameter.
             * @param typeUuid Uuid of parameter type.
             * @param direction Direction kind of parameter.
             * @id _smp2_Smp.xml_Smp.Publication.IPublishOperation.PublishParameter
             */
            def void PublishParameter(in Smp.String8 name, in Smp.String8 description, in Smp.Uuid typeUuid, in ParameterDirectionKind direction = ParameterDirectionKind.PDK_In) throws TypeNotRegistered, Smp.DuplicateName, Smp.InvalidObjectName, InvalidParameterDirection, Smp.InvalidType
        }
    }

    /**
     * Namespace for simulation services
     *
     * @id _smp2_Smp.xml_Smp.Services
     */
    namespace Services
    {
        /**
         * This interface is implemented by the Link Registry Service.
         *
         * @uuid f54cf5c5-f92c-3b11-a204-d5bc12d8bb5a
         * @id _12_1_f810373_1203600792294_555883_9056
         */
        public interface ILinkRegistry extends Smp.IService
        {
            /**
             * Add a link from source component to target component.
             * This increments the link count between source and target.
             *
             * @param source Source component of link (i.e. the component that links to another component).
             * @param target Target component of link (i.e. the component that is being linked to by another component).
             * @id _12_1_f810373_1203600965334_46380_9209
             */
            def void AddLink(inout Smp.IComponent source, @Attributes.Const in Smp.IComponent target)

            /**
             * Returns the number of links between source and target.
             * This number is incremented each time AddLink() is called, and decremented each time that RemoveLink() is called.
             *
             * @param source Source component of link (i.e. the component that links to another component).
             * @param target Target component of link (i.e. the component that is being linked to by another component).
             * @return True if such a link has been added before (and not been removed), false otherwise.
             * @id _12_1_f810373_1203601099168_115887_9220
             */
            @Attributes.Const
            def Smp.UInt32 ReturnParameter GetLinkCount(@Attributes.Const in Smp.IComponent source, @Attributes.Const in Smp.IComponent target)

            /**
             * Remove a link between source and target that has been added to the service using AddLink() before.
             * This decrements the link count between source and target.
             *
             * @param source Source component of link (i.e. the component that links to another component).
             * @param target Target component of link (i.e. the component that is being linked to by another component).
             * @return True if the link count between source and target had been positive and has been decremented, false if the link count had already been 0.
             * @id _12_1_f810373_1203601269294_981245_9232
             */
            def Smp.Bool ReturnParameter RemoveLink(in Smp.IComponent source, @Attributes.Const in Smp.IComponent target)

            /**
             * Returns a collection of all sources that have a link to the given target.
             *
             * @param target Target component to return link sources for.
             * @return Collection of source components which link to the given target.
             * @id _12_1_f810373_1203601083085_652063_9216
             */
            @Attributes.Const
            def @Attributes.ByPointer @Attributes.Const Smp.ComponentCollection ReturnParameter GetLinkSources(@Attributes.Const in Smp.IComponent target)

            /**
             * Returns true if all sources linking to the given target can be asked to remove their link(s), false otherwise.
             *
             * @param target Target component to check for links.
             * @return True if all links to the given target can be removed, false otherwise.
             * @id _12_1_f810373_1203601199063_733501_9227
             */
            def Smp.Bool ReturnParameter CanRemove(@Attributes.Const in Smp.IComponent target)

            /**
             * Removes all links to the given target.
             *
             * @param target Target component of link (i.e. the component that is being linked to by other components).
             * @id _12_1_f810373_1203601305977_70277_9236
             */
            def void RemoveLinks(@Attributes.Const in Smp.IComponent target)
        }

        /**
         * This exception is raised when trying to subscribe an entry point to an event that is already subscribed.
         *
         * @uuid 1ea1e641-41e8-31a8-97f5-423c08699742
         * @id _12_1_910029a_1199886955754_604123_2264
         */
