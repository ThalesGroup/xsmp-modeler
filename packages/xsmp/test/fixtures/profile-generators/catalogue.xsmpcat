catalogue ProfileGenerators

namespace demo
{
    namespace support
    {
        /** @uuid 11111111-1111-4111-8111-111111111111 */
        public enum Mode
        {
            Off = 0,
            On = 1
        }

        /** @uuid 22222222-2222-4222-8222-222222222222 */
        public integer Counter extends Int32

        /** @uuid 33333333-3333-4333-8333-333333333333 */
        public float Ratio extends Float64

        /** @uuid 44444444-4444-4444-8444-444444444444 */
        public string Label[32]

        /** @uuid 55555555-5555-4555-8555-555555555555 */
        public using LabelRef = Label*

        /** @uuid 66666666-6666-4666-8666-666666666666 */
        public array CounterArray = Counter[3]

        /**
         * @type SupportNative
         * @location demo/support/SupportNative.h
         * @uuid 77777777-7777-4777-8777-777777777777
         */
        public native SupportNative

        /** @uuid 88888888-8888-4888-8888-888888888888 */
        public struct Payload
        {
            constant Bool DefaultEnabled = true
            field Bool enabled = false
            field Counter count = 0
        }

        /** @uuid 99999999-9999-4999-8999-999999999999 */
        public class DeviceBase
        {
            constant Bool HasState = true
            field Bool active = false
            def void reset()
            property Bool Active -> active
        }

        /** @uuid aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa */
        public exception DeviceError
        {
        }

        /** @uuid bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb */
        public interface IDevice
        {
            constant Bool Ready = false
            def Bool ping(in Ratio requested, out Float64 measured)
            property Bool connected
        }

        /** @uuid cccccccc-cccc-4ccc-8ccc-cccccccccccc */
        public event TickEvent extends Counter

        /** @uuid dddddddd-dddd-4ddd-8ddd-dddddddddddd */
        public event VoidEvent

        /** @uuid eeeeeeee-eeee-4eee-8eee-eeeeeeeeeeee */
        public service MonitorService
        {
            field Bool running = false
            def void start()
            property Bool Running -> running
        }

        /** @uuid ffffffff-ffff-4fff-8fff-ffffffffffff */
        public model ChildModel
        {
            field Bool childState = false
        }

        /** @uuid 12121212-1212-4212-8212-121212121212 */
        public model RootModel implements IDevice
        {
            field Label name = "root"
            field CounterArray counters = {0, 1, 2}
            field Payload payload = {true, 1}
            field Bool connectedState = false

            reference IDevice deviceRef
            reference ChildModel childRef
            container Smp.IComposite child

            entrypoint main
            eventsink TickEvent onTick
            eventsource VoidEvent onDone

            def Bool ping(in Ratio requested, out Float64 measured)
            property Bool connected -> connectedState
        }
    }
}
