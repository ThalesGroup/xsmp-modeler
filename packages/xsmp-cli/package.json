{
    "name": "@xsmp/cli",
    "version": "2.0.0",
    "description": "XSMP command line interface.",
    "type": "module",
    "private": true,
    "license": "MIT",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.js"
        }
    },
    "bin": {
        "xsmpproject-cli": "./bin/cli.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.src.json",
        "watch": "tsc --watch -p tsconfig.src.json",
        "lint": "eslint src",
        "test": "cd ../.. && npm run build && vitest run packages/xsmp-cli/test --config vitest.config.ts"
    },
    "dependencies": {
        "@xsmp/profile-esa-cdk": "2.0.0",
        "@xsmp/profile-xsmp-sdk": "2.0.0",
        "@xsmp/tool-adoc": "2.0.0",
        "@xsmp/tool-python": "2.0.0",
        "@xsmp/tool-smp": "2.0.0",
        "commander": "~14.0.3",
        "langium": "4.2.4",
        "xsmp": "2.0.0",
        "xsmp-tas-mdk": "2.0.0"
    }
}
