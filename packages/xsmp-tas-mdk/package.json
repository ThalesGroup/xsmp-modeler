{
    "name": "xsmp-tas-mdk",
    "displayName": "XSMP TAS-MDK",
    "description": "TAS MDK support for XSMP Modeler.",
    "version": "1.98.0",
    "publisher": "ydaveluy",
    "author": "ydaveluy",
    "homepage": "https://github.com/thalesgroup/xsmp-modeler",
    "repository": "https://github.com/thalesgroup/xsmp-modeler.git",
    "type": "module",
    "private": true,
    "license": "MIT",
    "bugs": "https://github.com/thalesgroup/xsmp-modeler/issues",
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "XSMP",
        "TAS-MDK",
        "modeling"
    ],
    "engines": {
        "vscode": "^1.82.0",
        "node": ">=20.19.0"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.js"
        }
    },
    "extensionDependencies": [
        "ydaveluy.xsmp-modeler"
    ],
    "contributes": {
        "xsmp": [
            {
                "descriptor": "./lib/tas-mdk.xsmpprofile",
                "handler": "./lib/contributor.js",
                "apiVersion": "^1.0.0",
                "deprecatedAliases": [
                    "org.eclipse.xsmp.profile.tas-mdk"
                ]
            }
        ]
    },
    "files": [
        "LICENSE",
        "lib/**",
        "package.json",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.src.json && npm run build:assets",
        "build:assets": "node ../../scripts/package-assets.mjs package",
        "watch": "tsc --watch -p tsconfig.src.json",
        "lint": "eslint src",
        "package": "npm run build && vsce package --no-dependencies",
        "test": "cd ../.. && npm run build && vitest run packages/xsmp-tas-mdk/test --config vitest.config.ts"
    },
    "dependencies": {
        "langium": "4.2.1",
        "xsmp": "1.98.0"
    }
}
