{
    "compilerOptions": {
        "target": "ES2023",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2023", "DOM"],
        "types": ["node"],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "composite": true,
        "strict": true,
        "noUnusedLocals": true,
        "noImplicitReturns": true,
        "noImplicitOverride": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleDetection": "force",
        "paths": {
            "@xsmp/core": ["./packages/xsmp/src/index.ts"],
            "@xsmp/core/ast": ["./packages/xsmp/src/generated/ast.ts"],
            "@xsmp/core/ast-partial": ["./packages/xsmp/src/generated/ast-partial.ts"],
            "@xsmp/core/contributions": ["./packages/xsmp/src/contributions/index.ts"],
            "@xsmp/core/grammar": ["./packages/xsmp/src/generated/grammar.ts"],
            "@xsmp/core/generator": ["./packages/xsmp/src/generator/index.ts"],
            "@xsmp/core/generator/cpp": ["./packages/xsmp/src/generator/cpp/index.ts"],
            "@xsmp/core/lsp": ["./packages/xsmp/src/lsp/index.ts"],
            "@xsmp/core/references": ["./packages/xsmp/src/references/index.ts"],
            "@xsmp/core/smp": ["./packages/xsmp/src/smp/index.ts"],
            "@xsmp/core/smp/*": ["./packages/xsmp/src/smp/*.ts"],
            "@xsmp/core/utils": ["./packages/xsmp/src/utils/index.ts"],
            "@xsmp/core/validation": ["./packages/xsmp/src/validation/index.ts"],
            "@xsmp/core/wizard": ["./packages/xsmp/src/wizard/index.ts"],
            "@xsmp/core/wizard/templates": ["./packages/xsmp/src/wizard/templates.ts"],
            "@xsmp/core/workspace": ["./packages/xsmp/src/workspace/index.ts"],
            "@xsmp/cli": ["./packages/xsmp-cli/src/index.ts"],
            "@xsmp/tool-smp": ["./packages/xsmp-tool-smp/src/index.ts"],
            "@xsmp/tool-adoc": ["./packages/xsmp-tool-adoc/src/index.ts"],
            "@xsmp/tool-python": ["./packages/xsmp-tool-python/src/index.ts"],
            "@xsmp/profile-xsmp-sdk": ["./packages/xsmp-profile-xsmp-sdk/src/index.ts"],
            "@xsmp/profile-esa-cdk": ["./packages/xsmp-profile-esa-cdk/src/index.ts"],
            "xsmp-tas-mdk": ["./packages/xsmp-tas-mdk/src/index.ts"]
        }
    },
    "include": [
        "**/src/**/*",
        "**/test/**/*"
    ],
    "exclude": [
        "**/lib/**/*",
        "**/out/**/*",
        "**/node_modules/**/*"
    ]
}
