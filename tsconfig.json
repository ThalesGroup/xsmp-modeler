{
    "compilerOptions": {
        "target": "ES2017",
        "module": "Node16",
        "lib": ["ESNext"],
        "sourceMap": true,
        "outDir": "out",
        "tsBuildInfoFile": ".tsbuildinfo/extension.tsbuildinfo",
        "baseUrl": ".",
        "paths": {
            "xsmp": ["src/index.ts"],
            "xsmp/ast": ["src/ast/index.ts"],
            "xsmp/ast-partial": ["src/ast-partial/index.ts"],
            "xsmp/contributions": ["src/contributions/index.ts"],
            "xsmp/grammar": ["src/grammar/index.ts"],
            "xsmp/generator": ["src/generator/index.ts"],
            "xsmp/generator/cpp": ["src/generator/cpp/index.ts"],
            "xsmp/lsp": ["src/lsp/index.ts"],
            "xsmp/references": ["src/references/index.ts"],
            "xsmp/utils": ["src/utils/index.ts"],
            "xsmp/validation": ["src/validation/index.ts"],
            "xsmp/wizard": ["src/wizard/index.ts"],
            "xsmp/workspace": ["src/workspace/index.ts"]
        },
        "strict": true,
        "noUnusedLocals": true,
        "noImplicitReturns": true,
        "noImplicitOverride": true,
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "out",
        "node_modules"
    ]
}
