// A launch configuration that launches the extension inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "preLaunchTask": "Build XSMP Workspace",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/packages/xsmp-vscode",
                "--extensionDevelopmentPath=${workspaceFolder}/packages/xsmp-profile-tas-mdk/vscode"
            ],
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/packages/xsmp-vscode/out/**/*.cjs",
                "${workspaceFolder}/packages/xsmp-profile-tas-mdk/vscode/lib/**/*.js"
            ]
        },
        {
            "name": "Run Extension (Examples Workspace)",
            "type": "extensionHost",
            "request": "launch",
            "preLaunchTask": "Build XSMP Workspace",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/packages/xsmp-vscode",
                "--extensionDevelopmentPath=${workspaceFolder}/packages/xsmp-profile-tas-mdk/vscode",
                "${workspaceFolder}/examples/examples.code-workspace"
            ],
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/packages/xsmp-vscode/out/**/*.cjs",
                "${workspaceFolder}/packages/xsmp-profile-tas-mdk/vscode/lib/**/*.js"
            ]
        },
        {
            "name": "Attach to Language Server",
            "type": "node",
            "port": 6009,
            "request": "attach",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/packages/xsmp-vscode/out/**/*.cjs",
                "${workspaceFolder}/packages/xsmp-profile-tas-mdk/vscode/lib/**/*.js",
                "${workspaceFolder}/node_modules/langium"
            ]
        }
    ]
}
